# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Gemini AI Configuration
# 클라이언트에는 Gemini 키를 두지 않는다. VITE_ 접두사 변수는 프론트엔드 번들에 평문으로 박힌다.
# AI 인사이트는 supabase/functions/gemini-insight Edge Function을 경유하며,
# 키는 Supabase Secret으로만 설정한다:
#   supabase secrets set GEMINI_API_KEY=<key> GEMINI_MODEL=gemini-3.5-flash
# Get your API key from: https://aistudio.google.com/apikey
